  allLines:
  - side: 0
    characterName: Loreen
    characterSprite: {fileID: 21300000, guid: 146a6ce1894c7084984f7771ba7e263e, type: 3}
    sentence: "I had my reservations about you, I\u2019ve got to admit. But you turned
      out to be charming in a way that made me feel weirdly safe. Should I be afraid
      of that?"
    eventTrigger: 
    choices: []
  - side: 1
    characterName: Ary
    characterSprite: {fileID: 21300000, guid: ece41423a199ba04f8804d355c231cbb, type: 3}
    sentence: "Coming from a dangerous woman such as yourself, it makes me wonder
      the same thing. It\u2019s been a while since I connected with someone and actually
      enjoyed myself on a date."
    eventTrigger: 
    choices: []
  - side: 2
    characterName: Counselor
    characterSprite: {fileID: 0}
    sentence: Would you two be interested in going on a second date?
    eventTrigger: 
    choices: []
  - side: 0
    characterName: Loreen
    characterSprite: {fileID: 0}
    sentence: "I\u2019d be open to that."
    eventTrigger: 
    choices: []
  - side: 1
    characterName: Ary
    characterSprite: {fileID: 0}
    sentence: "You\u2019d be open? Damn, I\u2019m hurt."
    eventTrigger: 
    choices: []
  - side: 0
    characterName: Loreen
    characterSprite: {fileID: 0}
    sentence: "Oh fine, I\u2019d like that, Counselor."
    eventTrigger: 
    choices: []
  - side: 1
    characterName: Ary
