    choices: []
  - side: 1
    characterName: Elroi
    characterSprite: {fileID: 21300000, guid: 6845c902b4dff3b438ed3a722b170f07, type: 3}
    sentence: "Heh. The pleasure is mine, Iro. Err- Io, was it? \r                                                                                
