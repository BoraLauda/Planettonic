    eventTrigger: 
    choices: []
  - side: 0
    characterName: Io
    characterSprite: {fileID: 0}
    sentence: "Yup, and don\u2019t worry my name\u2019s been mispronounced a WHOLE
      lot before."
    eventTrigger: 
    choices: []
  - side: 1
    characterName: Elroi
    characterSprite: {fileID: 21300000, guid: 940a91f339e1825439b9f6d15b9c98fa, type: 3}
    sentence: "Right, okay. Soo wanna take a look at the menu? \u2018Cause this guy
