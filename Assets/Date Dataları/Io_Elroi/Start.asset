  - side: 0
    characterName: Io
    characterSprite: {fileID: -1160322238068995058, guid: e79cf994b0112f542bb5904bcd06966b, type: 3}
    sentence: "Hey Elroi, it\u2019s nice to meet you. I took a look at your profile
      summary just before we zapped here and uh, you seem really cool.\r\n"
