  - side: 1
    characterName: Elroi
    characterSprite: {fileID: 0}
    sentence: "Well, I certainly didn\u2019t.\r\n"
    eventTrigger: 
    choices: []
  - side: 0
    characterName: Io
    characterSprite: {fileID: 0}
    sentence: "It\u2019s not nice that that\u2019s the first thing you think of when
      you look at my arms. I can do a lot more than please people with them and that\u2019s
